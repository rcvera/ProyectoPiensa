// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  SUPERVISOR
  EMPLOYEE
}

enum IncidentType {
  ACCIDENTE
  DANO_VEHICULO
  FALTA_INSUMO
  CONFLICTO
  OTRO
}

enum IncidentStatus {
  PENDIENTE
  REVISADO
  CERRADO
}

model Position {
  id     String  @id @default(uuid())
  name   String  @unique
  active Boolean @default(true)

  users User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id String @id @default(uuid())

  name     String
  email    String  @unique
  password String
  cedula   String? @unique

  role Role @default(EMPLOYEE)

  active Boolean @default(true)

  phone      String?
  positionId String?
  position   Position? @relation(fields: [positionId], references: [id])

  assignments       Assignment[]
  attendances       Attendance[]
  overtimes         Overtime[]
  incidents         Incident[]       @relation("EmployeeIncidents")
  reviewedIncidents Incident[]       @relation("ReviewerIncidents")
  notifications     Notification[]
  workloadSurveys   WorkloadSurvey[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Shift {
  id String @id @default(uuid())

  name      String
  startTime String?
  endTime   String?

  active Boolean @default(true)

  assignments Assignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Assignment {
  id String @id @default(uuid())

  userId  String
  shiftId String

  date DateTime @db.Date

  published   Boolean   @default(false)
  publishedAt DateTime?

  assignedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  shift Shift @relation(fields: [shiftId], references: [id])

  @@unique([userId, date])
}

model Attendance {
  id String @id @default(uuid())

  userId String

  checkIn    DateTime
  breakStart DateTime?
  breakEnd   DateTime?
  checkOut   DateTime?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  overtimes Overtime[]
}

model Overtime {
  id String @id @default(uuid())

  userId String

  attendanceId String

  workedHours Float

  overtimeHours Float

  date DateTime

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  attendance Attendance @relation(fields: [attendanceId], references: [id])
}

model Incident {
  id String @id @default(uuid())

  userId String

  type        IncidentType
  description String
  photoUrl    String?

  status         IncidentStatus @default(PENDIENTE)
  adminResponse  String?
  reviewedById   String?
  reviewedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User           @relation("EmployeeIncidents", fields: [userId], references: [id])
  reviewedBy   User?          @relation("ReviewerIncidents", fields: [reviewedById], references: [id])
  notifications Notification[]
}

model Notification {
  id String @id @default(uuid())

  userId     String
  incidentId String?

  title   String
  message String
  read    Boolean @default(false)

  createdAt DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id])
  incident Incident? @relation(fields: [incidentId], references: [id])
}

model WorkloadSurvey {
  id     String @id @default(uuid())
  userId String
  month  Int
  year   Int

  hoursFeeling   Int?
  physicalLoad   Int?
  emotionalLoad  Int?
  comments       String?

  completedAt DateTime?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, month, year])
}
