// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  SUPERVISOR
  EMPLOYEE
}

enum IncidentType {
  ACCIDENTE
  DANO_VEHICULO
  FALTA_INSUMO
  CONFLICTO
  OTRO
}

enum IncidentStatus {
  PENDIENTE
  REVISADO
  CERRADO
}

enum JustificationType {
  ENFERMEDAD
  CALAMIDAD_DOMESTICA
  LUTO
  OTRO
}

enum JustificationStatus {
  PENDIENTE
  APROBADA
  RECHAZADA
}

model Position {
  id     String  @id @default(uuid())
  name   String  @unique
  active Boolean @default(true)

  employees Employee[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id String @id @default(uuid())

  email    String @unique
  password String

  role Role @default(EMPLOYEE)

  active Boolean @default(true)

  employee Employee?

  assignments       Assignment[]
  attendances       Attendance[]
  overtimes         Overtime[]
  incidents         Incident[]       @relation("EmployeeIncidents")
  reviewedIncidents Incident[]       @relation("ReviewerIncidents")
  notifications     Notification[]
  workloadSurveys   WorkloadSurvey[]
  payslips          Payslip[]

  justifications         Justification[] @relation("EmployeeJustifications")
  reviewedJustifications Justification[] @relation("JustificationReviewer")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Employee {
  id     String @id @default(uuid())
  userId String @unique

  name   String
  cedula String? @unique
  phone  String?

  baseSalary Float?

  positionId String?
  position   Position? @relation(fields: [positionId], references: [id])

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Shift {
  id String @id @default(uuid())

  name      String
  startTime String?
  endTime   String?

  active Boolean @default(true)

  assignments Assignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Assignment {
  id String @id @default(uuid())

  userId  String
  shiftId String

  date DateTime @db.Date

  published   Boolean   @default(false)
  publishedAt DateTime?

  assignedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  shift Shift @relation(fields: [shiftId], references: [id])

  @@unique([userId, date])
}

model Attendance {
  id String @id @default(uuid())

  userId String

  checkIn    DateTime
  breakStart DateTime?
  breakEnd   DateTime?
  checkOut   DateTime?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  overtimes Overtime[]
}

model Overtime {
  id String @id @default(uuid())

  userId String

  attendanceId String

  workedHours Float

  overtimeHours Float

  overtimeHours50  Float @default(0)
  overtimeHours100 Float @default(0)

  date DateTime

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  attendance Attendance @relation(fields: [attendanceId], references: [id])
}

model Payslip {
  id String @id @default(uuid())

  userId String

  month Int
  year  Int

  baseSalary Float

  expectedDays Int
  workedDays   Int
  absenceDays  Int
  lateMinutes  Int

  overtimeHours50  Float
  overtimeHours100 Float
  overtimePay      Float

  grossIncome      Float
  iessPersonal     Float
  iessPatronal     Float
  absenceDeduction Float
  lateDeduction    Float
  netPay           Float

  generatedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, month, year])
}

model Incident {
  id String @id @default(uuid())

  userId String

  type        IncidentType
  description String
  photoUrl    String?

  status         IncidentStatus @default(PENDIENTE)
  adminResponse  String?
  reviewedById   String?
  reviewedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User           @relation("EmployeeIncidents", fields: [userId], references: [id])
  reviewedBy   User?          @relation("ReviewerIncidents", fields: [reviewedById], references: [id])
  notifications Notification[]
}

model Notification {
  id String @id @default(uuid())

  userId         String
  incidentId     String?
  justificationId String?

  title   String
  message String
  read    Boolean @default(false)

  createdAt DateTime @default(now())

  user          User          @relation(fields: [userId], references: [id])
  incident      Incident?     @relation(fields: [incidentId], references: [id])
  justification Justification? @relation(fields: [justificationId], references: [id])
}

model Justification {
  id String @id @default(uuid())

  userId String

  // Día que se está justificando (falta, no la fecha en que se reporta).
  date DateTime @db.Date

  type        JustificationType
  description String

  // Certificado médico, acta de defunción, etc. Imagen o PDF.
  documentUrl String?

  status        JustificationStatus @default(PENDIENTE)
  adminResponse String?
  reviewedById  String?
  reviewedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user          User           @relation("EmployeeJustifications", fields: [userId], references: [id])
  reviewedBy    User?          @relation("JustificationReviewer", fields: [reviewedById], references: [id])
  notifications Notification[]
}

model WorkloadSurvey {
  id     String @id @default(uuid())
  userId String
  month  Int
  year   Int

  hoursFeeling   Int?
  physicalLoad   Int?
  emotionalLoad  Int?
  comments       String?

  completedAt DateTime?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, month, year])
}
